{
  "name": "nudge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "esbuild": "^0.25.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    },
    "@rollup/plugin-terser": {
      "serialize-javascript": "^7.0.5"
    }
  },
  "scripts": {
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend"
  }
}
