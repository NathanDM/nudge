# Copy to .env for local dev. Production values injected by GitHub Actions.
POSTGRES_USER=nudge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nudge
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nudge:changeme@localhost:5432/nudge
JWT_SECRET=change-this-in-production
CORS_ORIGIN=http://localhost:5173
# Used by docker-compose.prod.yml (set automatically in CI):
GITHUB_OWNER=your-github-username
GITHUB_REPO=nudge
